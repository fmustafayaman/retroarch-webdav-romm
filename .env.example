# RomM instance this shim talks to.
ROMM_BASE_URL=https://romm.example.com

# Auth: either ROMM_API_TOKEN (a client token from RomM's Settings > Client
# Tokens, sent as a Bearer token — takes precedence if set), or a plain
# ROMM_USERNAME/ROMM_PASSWORD pair (sent as HTTP Basic). Either way, this is
# a single RomM account whose saves/states are what gets synced.
ROMM_API_TOKEN=
ROMM_USERNAME=
ROMM_PASSWORD=

# Fixed RomM save "slot" this shim tags every save it creates with. RomM
# pairs saves on (rom_id, slot) and silently renames the file on upload, so
# filename-based matching doesn't work for saves — see README. Default is
# "autosave", the same slot name RomM's own reference clients use for a
# game's primary save, so this shim's saves pair with rather than fragment
# away from anything else in your setup using that convention. Only change
# this if you're running more than one instance of this shim against the
# same RomM account and need them to stay independent.
ROMM_SAVE_SLOT=autosave

# Max history rows kept per (rom, save-slot) / (rom, state-slot). Every
# upload creates a new row in RomM rather than overwriting the last one
# (so older saves/states are always recoverable by browsing WebDAV — see
# README), which means history grows forever unless pruned. Once a slot
# passes this count, the oldest rows beyond it are deleted right after the
# upload that pushed it over. Set to 0 to disable pruning (unlimited
# history, matches this shim's original behavior).
HISTORY_KEEP_COUNT=20

# RomM platform slug -> RetroArch core folder name, OPTIONAL — overrides/
# extends the built-in defaults in emulatorNames.ts. Only matters for
# saves/states with no "emulator" field at all (RomM's own web player,
# EmulatorJS, never sets one), so this shim can guess where RetroArch would
# actually look for them locally instead of leaving them in a flat,
# unrecognized path. Only needed if you use a different core than the
# built-in default for a platform, e.g. bsnes instead of Snes9x for SNES.
# DEFAULT_CORE_BY_PLATFORM={"snes":"bsnes"}
DEFAULT_CORE_BY_PLATFORM={}

# PSP (PPSSPP core) save-folder-to-rom mapping — OPTIONAL. PSP saves match
# to a RomM rom automatically via PARAM.SFO's title (which PPSSPP already
# sends as part of every save), no setup needed for the normal case. Only
# fill this in for a specific game if the shim logs that it couldn't
# auto-match that game's title. Key is the game's serial (the PSP save
# folder name minus its trailing "DATA<N>", e.g. "ULUS10336DATA0" ->
# "ULUS10336"), value is the rom's title exactly as it appears in RomM —
# see README "PSP (PPSSPP) saves".
# PSP_SERIAL_MAP={"ULUS10336":"Crisis Core - Final Fantasy VII (USA)"}
PSP_SERIAL_MAP={}

# Credentials RetroArch's Cloud Sync (WebDAV) will authenticate with.
# These are independent of the RomM credentials above.
WEBDAV_USERNAME=
WEBDAV_PASSWORD=

# Shim's own listen address/port.
PORT=8080
BIND_ADDRESS=0.0.0.0

# trace | debug | info | warn | error
LOG_LEVEL=debug

# How long (seconds) RomM listing calls (platforms, roms-per-platform,
# saves, states, rom-by-id) are cached in memory. Matters most when
# browsing /roms/, /saves/, /states/ via a WebDAV client: a single browse
# fires a burst of near-simultaneous PROPFIND requests (including OS-level
# "._name" AppleDouble probes for every entry), and without caching each
# one re-fetches the same listings from RomM from scratch. Invalidated
# immediately on this shim's own save/state uploads/deletes, so a client
# that lists right after a write it just made still sees it. Set to 0 to
# disable and always hit RomM fresh.
CACHE_TTL_SECONDS=30
